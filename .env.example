# Required — Gemini via Google AI Studio (free tier).
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY="<google-ai-studio-api-key>"

# Required — web search for author/lab enrichment (free tier at https://tavily.com)
TAVILY_API_KEY="<tavily-api-key>"

# Optional — LangSmith tracing (recommended; makes every tool call + interrupt visible)
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="research-podcast-agent"

# --- Swapping the model provider (see utils/models.py) --------------------
# If using OpenAI:     uv sync --extra openai      then set OPENAI_API_KEY
# OPENAI_API_KEY="<openai-api-key>"
# If using Anthropic:  uv sync --extra anthropic   then set ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY="<anthropic-api-key>"
